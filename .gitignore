# OS / editor noise
**/.DS_Store
.idea
.project
.settings/*

# Rust
/target/
/Cargo.lock.bak

# Claude Code per-developer settings (permission allowlist, plugin
# enablement). Plugins like `understand-anything` are opt-in; collaborators
# can enable them locally without committing the choice.
.claude/settings.local.json
.claude/settings.json

# Stray TypeScript artifacts at the repo root. The legacy TS code lives
# in legacy/core_split/; these patterns catch anything regenerated by an
# accidental `npm install` / `npm run build` at the repo root.
/node_modules/
/build/
/dist/
/.wrangler/
/packages/
/bench-results.json
/BENCH_REPORT.md
*.tsbuildinfo

# Local env override files
.env.local
.env.*.local

# Tauri build artifacts (when the desktop crate is wired)
crates/synergismforkd_ui_desktop/gen/
crates/synergismforkd_ui_desktop/target/

# Criterion bench artifacts (regenerated by `cargo bench`)
target/criterion/

# Legacy TS folders retain their own gitignored artifacts via the rules
# below; the legacy folders are frozen reference, not actively built.
legacy/core_split/**/node_modules/
legacy/core_split/**/dist/
legacy/core_split/**/build/
legacy/core_split/**/.wrangler/
legacy/core_split/**/*.tsbuildinfo
legacy/core_split/.husky/_/
legacy/core_split/packages/logic/bench-results.json
legacy/core_split/packages/logic/BENCH_REPORT.md

legacy/original/node_modules/
legacy/original/dist/
legacy/original/build/
legacy/original/.husky/_/
