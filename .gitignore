# OS / editor noise
**/.DS_Store
.idea
.project
.settings/*

# Rust
/target/
/Cargo.lock.bak

# Claude Code local-only settings (per-user permission allowlist, etc.)
.claude/settings.local.json

# Local env override files
.env.local
.env.*.local

# Tauri build artifacts (when the desktop crate is wired)
crates/synergismforkd_ui_desktop/gen/
crates/synergismforkd_ui_desktop/target/

# Criterion bench artifacts (regenerated by `cargo bench`)
target/criterion/

# Legacy TS folders retain their own gitignored artifacts via the rules
# below; the legacy folders are frozen reference, not actively built.
legacy_core_split/**/node_modules/
legacy_core_split/**/dist/
legacy_core_split/**/build/
legacy_core_split/**/.wrangler/
legacy_core_split/**/*.tsbuildinfo
legacy_core_split/.husky/_/
legacy_core_split/packages/logic/bench-results.json
legacy_core_split/packages/logic/BENCH_REPORT.md

legacy_original/node_modules/
legacy_original/dist/
legacy_original/build/
legacy_original/.husky/_/
