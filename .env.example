# Build-time environment variables. Copy to .env.development for local dev,
# or set these in the Cloudflare Pages dashboard for production / preview
# deploys. Any unset variable falls back to the legacy synergism.cc defaults.

# Base URL for the backend HTTP API (login, payments, messages, translations,
# etc.). No trailing slash.
API_BASE_URL=https://synergism.cc

# Base URL for the consumables WebSocket. No trailing path.
WS_BASE_URL=wss://synergism.cc

# Hostname of the canonical web deploy — used to gate browser-only purchase UI
# (Stripe/PayPal flows that require the backend's own keys) and to guard MSW's
# onUnhandledRequest. Bare hostname, no scheme.
CANONICAL_HOST=synergism.cc
