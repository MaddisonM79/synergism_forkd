{
  "name": "synergismofficial",
  "version": "4.1.1",
  "description": "",
  "main": "dist/bundle.js",
  "engines": {
    "node": ">=22.21.0"
  },
  "dependencies": {
    "@paypal/paypal-js": "^9.7.0",
    "@ungap/custom-elements": "^1.3.0",
    "break_infinity.js": "^2.0.0",
    "clipboard": "^2.0.11",
    "dompurify": "^3.4.5",
    "fast-mersenne-twister": "^1.0.3",
    "i18next": "^22.4.9",
    "lz-string": "^1.4.4",
    "mime-types": "^3.0.2",
    "rfdc": "^1.4.1",
    "worker-timers": "^8.0.31",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cloudflare-turnstile": "^0.2.2",
    "@types/jsdom": "^28.0.3",
    "@types/lz-string": "^1.5.0",
    "@types/mime-types": "^3.0.1",
    "concurrently": "^9.2.1",
    "dprint": "^0.54.0",
    "fast-check": "^3.23.2",
    "htmlhint": "^1.9.2",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "msw": "^2.14.6",
    "oxlint": "^1.66.0",
    "oxlint-tsgolint": "^0.23.0",
    "stylelint": "^14.8.2",
    "stylelint-config-standard": "^25.0.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.14",
    "vite-plugin-static-copy": "^3.4.0",
    "vitest": "^3.2.4",
    "wrangler": "^4.0.0"
  },
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "preview:cf": "npm run cloudflare:build && npx wrangler pages dev build --port 3000",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "npx dprint fmt",
    "format": "npx dprint fmt",
    "csslint": "npx stylelint Synergism.css",
    "csslint:fix": "npx stylelint Synergism.css --fix",
    "htmllint": "npx htmlhint index.html",
    "build": "vite build",
    "build:esbuild": "vite build",
    "watch": "vite build --watch",
    "watch:esbuild": "vite build --watch",
    "check:tsc": "npx -p typescript tsc",
    "watch:tsc": "npx -p typescript tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky",
    "cloudflare:build": "vite build && npm run cloudflare:stage",
    "cloudflare:stage": "node scripts/stage.mjs",
    "msw:init": "npx -y msw init build --save",
    "check-circular": "madge --circular src/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pseudo-Corp/SynergismOfficial.git"
  },
  "keywords": [
    "synergism",
    "synergismofficial"
  ],
  "author": "MaddisonM79 (https://github.com/MaddisonM79)",
  "contributors": [
