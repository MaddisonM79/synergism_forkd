{
  "name": "synergismofficial",
  "version": "4.1.1",
  "private": true,
  "description": "",
  "engines": {
    "node": ">=22.21.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @synergism/web_ui",
    "preview": "npm run preview -w @synergism/web_ui",
    "preview:cf": "npm run cloudflare:build -w @synergism/web_ui && npx wrangler pages dev packages/web_ui/build --port 3000",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "npx dprint fmt",
    "format": "npx dprint fmt",
    "csslint": "npx stylelint packages/web_ui/Synergism.css",
    "csslint:fix": "npx stylelint packages/web_ui/Synergism.css --fix",
    "htmllint": "npx htmlhint packages/web_ui/index.html",
    "build": "npm run build -w @synergism/web_ui",
    "build:esbuild": "npm run build -w @synergism/web_ui",
    "watch": "npm run build -w @synergism/web_ui -- --watch",
    "watch:esbuild": "npm run build -w @synergism/web_ui -- --watch",
    "check:tsc": "tsc --build && tsc --noEmit -p packages/web_ui/tsconfig.json && tsc --noEmit -p packages/desktop_ui/tsconfig.json",
    "watch:tsc": "tsc --build --watch",
    "test": "npm test --workspaces --if-present",
    "test:watch": "npm run test:watch -w @synergism/web_ui",
    "prepare": "husky",
    "cloudflare:build": "npm run cloudflare:build -w @synergism/web_ui",
    "cloudflare:stage": "npm run cloudflare:stage -w @synergism/web_ui",
    "msw:init": "npm run msw:init -w @synergism/web_ui",
    "check-circular": "madge --circular packages/logic/src/ packages/web_ui/src/"
  },
  "devDependencies": {
    "@types/cloudflare-turnstile": "^0.2.2",
    "@types/jsdom": "^28.0.3",
    "@types/lz-string": "^1.5.0",
    "@types/mime-types": "^3.0.1",
    "concurrently": "^9.2.1",
    "dprint": "^0.54.0",
    "fast-check": "^3.23.2",
    "htmlhint": "^1.9.2",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "msw": "^2.14.6",
    "oxlint": "^1.66.0",
    "oxlint-tsgolint": "^0.23.0",
    "stylelint": "^14.8.2",
    "stylelint-config-standard": "^25.0.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.14",
    "vite-plugin-static-copy": "^3.4.0",
    "vitest": "^4.1.7",
    "wrangler": "^4.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pseudo-Corp/SynergismOfficial.git"
  },
  "keywords": [
    "synergism",
    "synergismofficial"
  ],
  "author": "MaddisonM79 (https://github.com/MaddisonM79)",
  "contributors": [
    {
      "name": "Platonic"
    },
    {
      "name": "Khafra"
    }
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Pseudo-Corp/SynergismOfficial/issues"
  },
  "homepage": "https://github.com/Pseudo-Corp/SynergismOfficial#readme"
}
