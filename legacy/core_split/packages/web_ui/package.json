{
  "name": "@synergism/web_ui",
  "version": "0.0.0",
  "private": true,
  "description": "Browser frontend for Synergism. Consumes @synergism/logic.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check:tsc": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "cloudflare:build": "vite build && npm run cloudflare:stage",
    "cloudflare:stage": "node ./scripts/stage.mjs",
    "msw:init": "npx -y msw init build --save"
  },
  "dependencies": {
    "@synergism/logic": "*",
    "@paypal/paypal-js": "^9.7.0",
    "@ungap/custom-elements": "^1.3.0",
    "break_infinity.js": "^2.0.0",
    "clipboard": "^2.0.11",
    "dompurify": "^3.4.9",
    "fast-mersenne-twister": "^1.0.3",
    "i18next": "^22.4.9",
    "lz-string": "^1.4.4",
    "mime-types": "^3.0.2",
    "rfdc": "^1.4.1",
    "worker-timers": "^8.0.31",
    "zod": "^3.25.76"
  },
  "msw": {
    "workerDirectory": [
      "build",
      ""
    ]
  }
}
