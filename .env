# Base build-time configuration. These defaults point at the legacy
# synergism.cc backend so an unconfigured build still works.
#
# Forks should override via:
#   - CF Pages dashboard environment variables (Production / Preview)
#   - .env.local for personal local-dev overrides (gitignored)
#
# Variables prefixed with VITE_ are exposed to client code via
# import.meta.env (see src/Config.ts) and substituted into index.html.

VITE_API_BASE_URL=https://synergism.cc
VITE_WS_BASE_URL=wss://synergism.cc
VITE_CANONICAL_HOST=synergism.cc
